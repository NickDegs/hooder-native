default_platform(:ios)

platform :ios do
  # Native SwiftUI (Hooder.xcodeproj, XcodeGen ile üretilir) → TestFlight.
  # Bundle id PWA ile AYNI: app.realvirtuality.landlord (aynı App Store uygulaması).
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      in_house:    false,
    )

    # Provisioning profili otomatik al/oluştur (push + applesignin yok; sade app-store)
    sigh(
      api_key:           api_key,
      app_identifier:    "app.realvirtuality.landlord",
      provisioning_name: "Hooder Distribution",
      force:             true,
      output_path:       "/tmp",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.message("Provisioning profili: #{profile_name}")

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id:               "SZF4T3P583",
      code_sign_identity:    "iPhone Distribution",
      bundle_identifier:     "app.realvirtuality.landlord",
      profile_name:          profile_name,
      path:                  "Hooder.xcodeproj",
    )

    build_ios_app(
      project:        "Hooder.xcodeproj",
      scheme:         "Hooder",
      configuration:  "Release",
      output_name:    "Hooder.ipa",
      export_method:  "app-store",
      export_options: {
        teamID: "SZF4T3P583",
        provisioningProfiles: {
          "app.realvirtuality.landlord" => profile_name,
        },
        signingStyle: "manual",
      },
      xcargs: "-clonedSourcePackagesDirPath /tmp/spm-cache",
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "Native (Swift) sürüm — Liquid Glass + offline uydu harita",
    )
  end
end

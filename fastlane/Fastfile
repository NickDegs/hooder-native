default_platform(:ios)

platform :ios do
  # Native SwiftUI (Hooder.xcodeproj, XcodeGen ile üretilir) → TestFlight.
  # Bundle id PWA ile AYNI: app.realvirtuality.landlord (aynı App Store uygulaması).
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      in_house:    false,
    )

    # OTOMATİK İMZA: Xcode App Attest dahil eksik capability'leri otomatik provisionlar
    # (-allowProvisioningUpdates + ASC API key). Manuel sigh App Attest entitlement'ını içermiyordu.
    update_code_signing_settings(
      use_automatic_signing: true,
      team_id:               "SZF4T3P583",
      bundle_identifier:     "app.realvirtuality.landlord",
      path:                  "Hooder.xcodeproj",
    )

    build_ios_app(
      project:        "Hooder.xcodeproj",
      scheme:         "Hooder",
      configuration:  "Release",
      output_name:    "Hooder.ipa",
      export_method:  "app-store",
      export_options: {
        teamID: "SZF4T3P583",
        signingStyle: "automatic",
      },
      xcargs: "-allowProvisioningUpdates -clonedSourcePackagesDirPath /tmp/spm-cache",
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
      changelog:                         "Native (Swift) sürüm — Liquid Glass + offline uydu harita",
    )
  end
end
